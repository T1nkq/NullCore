<ui:UiPage
    x:Class="Voidstrap.UI.Elements.Settings.Pages.InstanceDashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:Voidstrap.UI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:settings="clr-namespace:Voidstrap.UI.ViewModels.Settings"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Панель инстансов"
    d:DataContext="{d:DesignInstance Type=settings:InstanceDashboardViewModel}"
    d:DesignHeight="900"
    d:DesignWidth="900"
    Scrollable="True"
    mc:Ignorable="d">

    <ui:UiPage.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:InvertBooleanToVisibilityConverter x:Key="InvertBoolToVis" />
        <SolidColorBrush x:Key="DashboardPanelBrush" Color="#E80F141A" />
        <SolidColorBrush x:Key="DashboardPanelAltBrush" Color="#D9182028" />
        <SolidColorBrush x:Key="DashboardStrokeBrush" Color="#336EE7C8" />
        <SolidColorBrush x:Key="DashboardStrokeMutedBrush" Color="#283D4856" />
        <SolidColorBrush x:Key="DashboardAccentBrush" Color="#FF6EE7C8" />
        <SolidColorBrush x:Key="DashboardCyanBrush" Color="#FF7CB8FF" />

        <Style x:Key="MetricTileStyle" TargetType="Border">
            <Setter Property="Padding" Value="14" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="MinHeight" Value="92" />
            <Setter Property="Background" Value="{StaticResource DashboardPanelAltBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource DashboardStrokeMutedBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="7" />
        </Style>

        <Style x:Key="MetricLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}" />
        </Style>

        <Style x:Key="MetricValueStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,8,0,0" />
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        </Style>

        <Style x:Key="MutedTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
    </ui:UiPage.Resources>

    <StackPanel Margin="0,0,0,18">
        <Border
            Margin="0,0,0,14"
            Padding="16"
            Background="{StaticResource DashboardPanelBrush}"
            BorderBrush="{StaticResource DashboardStrokeMutedBrush}"
            BorderThickness="1"
            CornerRadius="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock
                            Text="Панель инстансов"
                            FontSize="24"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        <Border
                            Margin="10,3,0,0"
                            Padding="8,3"
                            VerticalAlignment="Top"
                            Background="#1E7CB8FF"
                            BorderBrush="{StaticResource DashboardStrokeBrush}"
                            BorderThickness="1"
                            CornerRadius="5">
                            <TextBlock
                                Text="Live"
                                FontSize="11"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource DashboardCyanBrush}" />
                        </Border>
                    </StackPanel>
                    <TextBlock
                        Margin="0,5,0,0"
                        Text="{Binding MonitoringStatusText}"
                        FontSize="13"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <TextBlock
                        Margin="0,2,0,0"
                        Text="{Binding LastUpdatedText}"
                        FontSize="12"
                        Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                    <StackPanel Margin="0,0,12,0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            Text="Авто"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <ui:ToggleSwitch IsChecked="{Binding IsAutoRefreshEnabled, Mode=TwoWay}" />
                    </StackPanel>
                    <ui:Button
                        Content="Обновить"
                        Icon="ArrowClockwise24"
                        Command="{Binding RefreshCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource MetricTileStyle}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Margin="0,0,6,0" Symbol="WindowMultiple20" />
                        <TextBlock Style="{StaticResource MetricLabelStyle}" Text="Окна" />
                    </StackPanel>
                    <TextBlock Style="{StaticResource MetricValueStyle}" Text="{Binding InstanceCount}" />
                    <TextBlock Style="{StaticResource MutedTextStyle}" Text="Найденные Roblox-клиенты" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource MetricTileStyle}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Margin="0,0,6,0" Symbol="Database20" />
                        <TextBlock Style="{StaticResource MetricLabelStyle}" Text="RAM всего" />
                    </StackPanel>
                    <TextBlock Style="{StaticResource MetricValueStyle}" Text="{Binding TotalMemoryText}" />
                    <TextBlock Style="{StaticResource MutedTextStyle}" Text="Суммарная рабочая память" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource MetricTileStyle}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Margin="0,0,6,0" Symbol="Pulse20" />
                        <TextBlock Style="{StaticResource MetricLabelStyle}" Text="CPU всего" />
                    </StackPanel>
                    <TextBlock Style="{StaticResource MetricValueStyle}" Text="{Binding TotalCpuText}" />
                    <TextBlock Style="{StaticResource MutedTextStyle}" Text="{Binding AverageCpuText, StringFormat={}В среднем на окно: {0}}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="3" Margin="0" Style="{StaticResource MetricTileStyle}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Margin="0,0,6,0" Symbol="Gauge20" />
                        <TextBlock Style="{StaticResource MetricLabelStyle}" Text="Самый тяжелый" />
                    </StackPanel>
                    <TextBlock Style="{StaticResource MetricValueStyle}" Text="{Binding HeaviestInstanceText}" />
                    <TextBlock Style="{StaticResource MutedTextStyle}" Text="Процесс с самой высокой RAM" />
                </StackPanel>
            </Border>
        </Grid>

        <Border
            Margin="0,0,0,14"
            Padding="14"
            Background="{StaticResource DashboardPanelAltBrush}"
            BorderBrush="{StaticResource DashboardStrokeMutedBrush}"
            BorderThickness="1"
            CornerRadius="7"
            Visibility="{Binding HasInstances, Converter={StaticResource InvertBoolToVis}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <ui:SymbolIcon
                    Grid.Column="0"
                    Margin="0,0,12,0"
                    VerticalAlignment="Top"
                    Symbol="DesktopPulse24" />
                <StackPanel Grid.Column="1">
                    <TextBlock
                        Text="Roblox-инстансы не запущены"
                        FontSize="15"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                    <TextBlock
                        Margin="0,4,0,0"
                        Text="Запусти Roblox, и здесь появятся состояние процесса, расход памяти, нагрузка CPU, аптайм и быстрые действия для каждого живого клиента."
                        Style="{StaticResource MutedTextStyle}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.2*" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <Border
                Grid.Column="0"
                Padding="1"
                Background="{StaticResource DashboardPanelBrush}"
                BorderBrush="{StaticResource DashboardStrokeMutedBrush}"
                BorderThickness="1"
                CornerRadius="7">
                <DataGrid
                    ItemsSource="{Binding Instances}"
                    SelectedItem="{Binding SelectedInstance, Mode=TwoWay}"
                    AutoGenerateColumns="False"
                    CanUserAddRows="False"
                    CanUserDeleteRows="False"
                    CanUserReorderColumns="False"
                    IsReadOnly="True"
                    HeadersVisibility="Column"
                    GridLinesVisibility="None"
                    RowHeight="38"
                    MinHeight="330"
                    MaxHeight="430"
                    BorderThickness="0"
                    Background="Transparent"
                    AlternatingRowBackground="{StaticResource DashboardPanelAltBrush}"
                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                    ScrollViewer.HorizontalScrollBarVisibility="Auto">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="PID" Binding="{Binding Pid}" Width="70" />
                        <DataGridTextColumn Header="Процесс" Binding="{Binding ProcessName}" Width="140" />
                        <DataGridTextColumn Header="RAM" Binding="{Binding MemoryText}" Width="90" />
                        <DataGridTextColumn Header="CPU" Binding="{Binding CpuText}" Width="70" />
                        <DataGridTextColumn Header="Аптайм" Binding="{Binding UptimeText}" Width="90" />
                        <DataGridTemplateColumn Header="Статус" Width="130">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border
                                        Padding="8,3"
                                        HorizontalAlignment="Left"
                                        CornerRadius="5"
                                        Background="{Binding StatusBrush}">
                                        <TextBlock
                                            Text="{Binding Status}"
                                            FontSize="12"
                                            FontWeight="SemiBold"
                                            Foreground="White" />
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Окно" Binding="{Binding WindowTitle}" Width="220" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border
                Grid.Column="2"
                Padding="14"
                Background="{StaticResource DashboardPanelBrush}"
                BorderBrush="{StaticResource DashboardStrokeMutedBrush}"
                BorderThickness="1"
                CornerRadius="7">
                <StackPanel>
                    <TextBlock
                        Text="Выбранный инстанс"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                    <TextBlock
                        Margin="0,3,0,14"
                        Text="{Binding SelectedInstance.ProcessLabel, TargetNullValue='Инстанс не выбран'}"
                        Style="{StaticResource MutedTextStyle}" />

                    <Grid Margin="0,0,0,12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,12,7" Text="RAM" Style="{StaticResource MetricLabelStyle}" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedInstance.MemoryText, TargetNullValue=-}" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,12,7" Text="Private RAM" Style="{StaticResource MetricLabelStyle}" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedInstance.PrivateMemoryText, TargetNullValue=-}" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,12,7" Text="CPU" Style="{StaticResource MetricLabelStyle}" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedInstance.CpuText, TargetNullValue=-}" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,0,12,7" Text="Запущен" Style="{StaticResource MetricLabelStyle}" />
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedInstance.StartedText, TargetNullValue=-}" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

                        <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,0,12,7" Text="Приоритет" Style="{StaticResource MetricLabelStyle}" />
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SelectedInstance.PriorityText, TargetNullValue=-}" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

                        <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,0,12,0" Text="Потоки" Style="{StaticResource MetricLabelStyle}" />
                        <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding SelectedInstance.ThreadCount, TargetNullValue=-}" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                    </Grid>

                    <TextBlock Text="Исполняемый файл" Style="{StaticResource MetricLabelStyle}" />
                    <TextBlock
                        Margin="0,4,0,14"
                        Text="{Binding SelectedInstance.ExecutablePath, TargetNullValue=Недоступно}"
                        TextWrapping="Wrap"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <ui:Button
                            Grid.Row="0"
                            Grid.Column="0"
                            Content="Копировать"
                            Icon="Copy24"
                            HorizontalAlignment="Stretch"
                            IsEnabled="{Binding HasSelectedInstance}"
                            Command="{Binding CopySelectedInfoCommand}" />
                        <ui:Button
                            Grid.Row="0"
                            Grid.Column="2"
                            Content="Папка"
                            Icon="FolderOpen24"
                            HorizontalAlignment="Stretch"
                            IsEnabled="{Binding HasSelectedInstance}"
                            Command="{Binding OpenSelectedFolderCommand}" />
                        <ui:Button
                            Grid.Row="1"
                            Grid.Column="0"
                            Grid.ColumnSpan="3"
                            Margin="0,8,0,0"
                            Content="Завершить"
                            Icon="Stop24"
                            Appearance="Danger"
                            HorizontalAlignment="Stretch"
                            IsEnabled="{Binding HasSelectedInstance}"
                            Command="{Binding EndSelectedCommand}" />
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </StackPanel>
</ui:UiPage>

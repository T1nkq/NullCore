<ui:UiPage
    x:Class="Voidstrap.UI.Elements.Settings.Pages.InstanceDashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:Voidstrap.UI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:settings="clr-namespace:Voidstrap.UI.ViewModels.Settings"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Instance Dashboard"
    d:DataContext="{d:DesignInstance Type=settings:InstanceDashboardViewModel}"
    d:DesignHeight="900"
    d:DesignWidth="900"
    Scrollable="True"
    mc:Ignorable="d">

    <ui:UiPage.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:InvertBooleanToVisibilityConverter x:Key="InvertBoolToVis" />

        <Style x:Key="MetricTileStyle" TargetType="Border">
            <Setter Property="Padding" Value="14" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="MinHeight" Value="92" />
            <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>

        <Style x:Key="MetricLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}" />
        </Style>

        <Style x:Key="MetricValueStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,8,0,0" />
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        </Style>

        <Style x:Key="MutedTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
    </ui:UiPage.Resources>

    <StackPanel Margin="0,0,14,18">
        <Grid Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock
                    Text="Instance Dashboard"
                    FontSize="24"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                <TextBlock
                    Margin="0,4,0,0"
                    Text="{Binding MonitoringStatusText}"
                    FontSize="13"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                <TextBlock
                    Margin="0,2,0,0"
                    Text="{Binding LastUpdatedText}"
                    FontSize="12"
                    Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                <StackPanel Margin="0,0,12,0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        Text="Auto"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <ui:ToggleSwitch IsChecked="{Binding IsAutoRefreshEnabled, Mode=TwoWay}" />
                </StackPanel>
                <ui:Button
                    Content="Refresh"
                    Icon="ArrowClockwise24"
                    Command="{Binding RefreshCommand}" />
            </StackPanel>
        </Grid>

        <Grid Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource MetricTileStyle}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Margin="0,0,6,0" Symbol="WindowMultiple20" />
                        <TextBlock Style="{StaticResource MetricLabelStyle}" Text="Instances" />
                    </StackPanel>
                    <TextBlock Style="{StaticResource MetricValueStyle}" Text="{Binding InstanceCount}" />
                    <TextBlock Style="{StaticResource MutedTextStyle}" Text="Detected Roblox clients" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource MetricTileStyle}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Margin="0,0,6,0" Symbol="Database20" />
                        <TextBlock Style="{StaticResource MetricLabelStyle}" Text="Total RAM" />
                    </StackPanel>
                    <TextBlock Style="{StaticResource MetricValueStyle}" Text="{Binding TotalMemoryText}" />
                    <TextBlock Style="{StaticResource MutedTextStyle}" Text="Working set total" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource MetricTileStyle}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Margin="0,0,6,0" Symbol="Pulse20" />
                        <TextBlock Style="{StaticResource MetricLabelStyle}" Text="Total CPU" />
                    </StackPanel>
                    <TextBlock Style="{StaticResource MetricValueStyle}" Text="{Binding TotalCpuText}" />
                    <TextBlock Style="{StaticResource MutedTextStyle}" Text="{Binding AverageCpuText, StringFormat={}Avg per instance: {0}}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="3" Margin="0" Style="{StaticResource MetricTileStyle}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Margin="0,0,6,0" Symbol="Gauge20" />
                        <TextBlock Style="{StaticResource MetricLabelStyle}" Text="Heaviest" />
                    </StackPanel>
                    <TextBlock Style="{StaticResource MetricValueStyle}" Text="{Binding HeaviestInstanceText}" />
                    <TextBlock Style="{StaticResource MutedTextStyle}" Text="Highest RAM process" />
                </StackPanel>
            </Border>
        </Grid>

        <Border
            Margin="0,0,0,14"
            Padding="14"
            Background="{DynamicResource ControlFillColorSecondaryBrush}"
            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Visibility="{Binding HasInstances, Converter={StaticResource InvertBoolToVis}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <ui:SymbolIcon
                    Grid.Column="0"
                    Margin="0,0,12,0"
                    VerticalAlignment="Top"
                    Symbol="DesktopPulse24" />
                <StackPanel Grid.Column="1">
                    <TextBlock
                        Text="No Roblox instances are running"
                        FontSize="15"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                    <TextBlock
                        Margin="0,4,0,0"
                        Text="Launch Roblox, then this dashboard will start showing process health, memory usage, CPU load, uptime, and controls for each live client."
                        Style="{StaticResource MutedTextStyle}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.2*" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <Border
                Grid.Column="0"
                Padding="1"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <DataGrid
                    ItemsSource="{Binding Instances}"
                    SelectedItem="{Binding SelectedInstance, Mode=TwoWay}"
                    AutoGenerateColumns="False"
                    CanUserAddRows="False"
                    CanUserDeleteRows="False"
                    CanUserReorderColumns="False"
                    IsReadOnly="True"
                    HeadersVisibility="Column"
                    GridLinesVisibility="None"
                    RowHeight="38"
                    MinHeight="330"
                    MaxHeight="430"
                    BorderThickness="0"
                    Background="Transparent"
                    AlternatingRowBackground="{DynamicResource ControlFillColorSecondaryBrush}"
                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                    ScrollViewer.HorizontalScrollBarVisibility="Auto">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="PID" Binding="{Binding Pid}" Width="70" />
                        <DataGridTextColumn Header="Process" Binding="{Binding ProcessName}" Width="140" />
                        <DataGridTextColumn Header="RAM" Binding="{Binding MemoryText}" Width="90" />
                        <DataGridTextColumn Header="CPU" Binding="{Binding CpuText}" Width="70" />
                        <DataGridTextColumn Header="Uptime" Binding="{Binding UptimeText}" Width="90" />
                        <DataGridTemplateColumn Header="Status" Width="130">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border
                                        Padding="8,3"
                                        HorizontalAlignment="Left"
                                        CornerRadius="5"
                                        Background="{Binding StatusBrush}">
                                        <TextBlock
                                            Text="{Binding Status}"
                                            FontSize="12"
                                            FontWeight="SemiBold"
                                            Foreground="White" />
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Window" Binding="{Binding WindowTitle}" Width="220" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border
                Grid.Column="2"
                Padding="14"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel>
                    <TextBlock
                        Text="Selected Instance"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                    <TextBlock
                        Margin="0,3,0,14"
                        Text="{Binding SelectedInstance.ProcessLabel, TargetNullValue='No instance selected'}"
                        Style="{StaticResource MutedTextStyle}" />

                    <Grid Margin="0,0,0,12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,12,7" Text="RAM" Style="{StaticResource MetricLabelStyle}" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedInstance.MemoryText, TargetNullValue=-}" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,12,7" Text="Private" Style="{StaticResource MetricLabelStyle}" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedInstance.PrivateMemoryText, TargetNullValue=-}" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,12,7" Text="CPU" Style="{StaticResource MetricLabelStyle}" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedInstance.CpuText, TargetNullValue=-}" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,0,12,7" Text="Started" Style="{StaticResource MetricLabelStyle}" />
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedInstance.StartedText, TargetNullValue=-}" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

                        <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,0,12,7" Text="Priority" Style="{StaticResource MetricLabelStyle}" />
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SelectedInstance.PriorityText, TargetNullValue=-}" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

                        <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,0,12,0" Text="Threads" Style="{StaticResource MetricLabelStyle}" />
                        <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding SelectedInstance.ThreadCount, TargetNullValue=-}" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                    </Grid>

                    <TextBlock Text="Executable" Style="{StaticResource MetricLabelStyle}" />
                    <TextBlock
                        Margin="0,4,0,14"
                        Text="{Binding SelectedInstance.ExecutablePath, TargetNullValue=Unavailable}"
                        TextWrapping="Wrap"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <ui:Button
                            Grid.Row="0"
                            Grid.Column="0"
                            Content="Trim RAM"
                            Icon="Pulse24"
                            HorizontalAlignment="Stretch"
                            IsEnabled="{Binding HasSelectedInstance}"
                            Command="{Binding TrimSelectedMemoryCommand}" />
                        <ui:Button
                            Grid.Row="0"
                            Grid.Column="2"
                            Content="Copy"
                            Icon="Copy24"
                            HorizontalAlignment="Stretch"
                            IsEnabled="{Binding HasSelectedInstance}"
                            Command="{Binding CopySelectedInfoCommand}" />
                        <ui:Button
                            Grid.Row="1"
                            Grid.Column="0"
                            Margin="0,8,0,0"
                            Content="Folder"
                            Icon="FolderOpen24"
                            HorizontalAlignment="Stretch"
                            IsEnabled="{Binding HasSelectedInstance}"
                            Command="{Binding OpenSelectedFolderCommand}" />
                        <ui:Button
                            Grid.Row="1"
                            Grid.Column="2"
                            Margin="0,8,0,0"
                            Content="End"
                            Icon="Stop24"
                            Appearance="Danger"
                            HorizontalAlignment="Stretch"
                            IsEnabled="{Binding HasSelectedInstance}"
                            Command="{Binding EndSelectedCommand}" />
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </StackPanel>
</ui:UiPage>

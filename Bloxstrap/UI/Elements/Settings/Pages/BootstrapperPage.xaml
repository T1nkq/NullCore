<ui:UiPage
    x:Class="Voidstrap.UI.Elements.Settings.Pages.BehaviourPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Voidstrap.UI.Elements.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
    xmlns:local="clr-namespace:Voidstrap.UI.Elements.Settings.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:Voidstrap.UI.ViewModels.Settings"
    xmlns:resources="clr-namespace:Voidstrap.Resources"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="BehaviourPage"
    d:DataContext="{d:DesignInstance Type=models:BehaviourViewModel}"
    d:DesignHeight="1500"
    d:DesignWidth="800"
    Scrollable="True"
    mc:Ignorable="d">
    <StackPanel>
        <TextBlock
            Margin="0,0,0,8"
            FontSize="14"
            Foreground="{StaticResource TextFillColorSecondaryBrush}"
            Text="{x:Static resources:Strings.Menu_Behaviour_Description}" />
    
    <TabControl Margin="0,0,14,14">
        <TabItem Header="General">
            <StackPanel Margin="10">

                    <controls:OptionControl 
                    x:Name="ConfirmLaunchOption"
                    Header="{x:Static resources:Strings.Menu_Behaviour_ConfirmLaunches_Title}" 
                    Description="{x:Static resources:Strings.Menu_Behaviour_ConfirmLaunches_Description}">
                    <ui:ToggleSwitch IsChecked="{Binding ConfirmLaunches, Mode=TwoWay}" />
                </controls:OptionControl>

                    <controls:OptionControl
                    Header="{x:Static resources:Strings.Menu_Behaviour_MultiInstances_Title}"
                    Description="{x:Static resources:Strings.Menu_Behaviour_MultiInstances_Description}">
                    <ui:ToggleSwitch IsChecked="{Binding MultiInstanceLaunching, Mode=TwoWay}" />
                </controls:OptionControl>

                    <controls:OptionControl
                    Header="{x:Static resources:Strings.Menu_Behaviour_ForceRobloxLanguage_Title}"
                    Description="{x:Static resources:Strings.Menu_Behaviour_ForceRobloxLanguage_Description}"
                    HelpLink="https://github.com/BloxstrapLabs/Bloxstrap/wiki/Information-on-Roblox-app-localisation">
                        <ui:ToggleSwitch IsChecked="{Binding ForceRobloxLanguage, Mode=TwoWay}" />
                    </controls:OptionControl>

                    <controls:OptionControl Description="Disables Background Window when Launching Roblox" Header="Disable Background Window">
                     <ui:ToggleSwitch IsChecked="{Binding BackgroundWindow, Mode=TwoWay}" />
                </controls:OptionControl>

                    <controls:OptionControl 
                  Header="Disable RobloxCrashHandler" 
                  Description="Disables the RobloxCrashHandler that runs on startup, improving memory and RAM efficiency.">
                        <ui:ToggleSwitch IsChecked="{Binding disablecrashhandleryayyysocool, Mode=TwoWay}" />
                    </controls:OptionControl>

                    <controls:OptionControl Description="Enables exclusive fullscreen mode. Overlays will not work in this." Header="Exclusive Fullscreen">
                        <ui:ToggleSwitch IsChecked="{Binding ExclusiveFullscreen, Mode=TwoWay}" />
                    </controls:OptionControl>

                    <ui:CardExpander Margin="0,8,0,0" IsExpanded="False">
                    <ui:CardExpander.Header>
                        <StackPanel>
                            <TextBlock FontSize="14" Text="Cleaner" />
                            <TextBlock Margin="0,2,0,0" FontSize="12" Text="NullCore will remove old data to save on space" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                        </StackPanel>
                    </ui:CardExpander.Header>
                    <StackPanel>
                        <controls:OptionControl Header="When should the files get deleted" Description="Files older than the set amount will be deleted.">
                            <ComboBox Width="200" Padding="10,5,10,5" ItemsSource="{Binding CleanerOptions, Mode=OneTime}" Text="{Binding CleanerOption, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Path=., Converter={StaticResource EnumNameConverter}}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </controls:OptionControl>
                        <controls:OptionControl Header="Cache" Description="When should the set amount be deleted.">
                            <ui:ToggleSwitch IsChecked="{Binding CleanerCache, Mode=TwoWay}" />
                        </controls:OptionControl>
                        <controls:OptionControl Header="Logs" Description="Old log files will be deleted.">
                            <ui:ToggleSwitch IsChecked="{Binding CleanerLogs, Mode=TwoWay}" />
                        </controls:OptionControl>
                        <controls:OptionControl Header="NullCore logs" Description="NullCore logs will be deleted.">
                            <ui:ToggleSwitch IsChecked="{Binding CleanerVoidstrap, Mode=TwoWay}" />
                        </controls:OptionControl>
                    </StackPanel>
                </ui:CardExpander>

                <ui:CardExpander Margin="0,8,0,0" IsExpanded="False">
                    <ui:CardExpander.Header>
                        <StackPanel>
                            <TextBlock FontSize="14" Text="Optimizations" />
                            <TextBlock Margin="0,2,0,0" FontSize="12" Text="Roblox optimization features" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                        </StackPanel>
                    </ui:CardExpander.Header>
                    <StackPanel>
                        <ui:CardControl Margin="0,8,0,0" Header="Some features may not work on all devices. Use them with caution.">
                            <Image HorizontalAlignment="Center" Source="pack://application:,,,/Resources/MessageBox/Warning.png" RenderOptions.BitmapScalingMode="HighQuality" Width="20" />
                        </ui:CardControl>

                        <controls:OptionControl Header="Set CPU cores for Roblox" Description="{Binding CpuSummary}">
                            <ComboBox Grid.Column="1"
                                    Margin="8,0,8,0"
                                    Padding="10,5,10,5"
                                    Width="200"
                                    ItemsSource="{Binding CpuOptions}"
                                    SelectedItem="{Binding SelectedCpuPriority, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </controls:OptionControl>

                        <controls:OptionControl
                            Header="NullCore CPU Core Limit"
                            Description="Limit how many CPU cores NullCore itself can use.">
                            <ComboBox Grid.Column="1"
                                    Margin="8,0,8,0"
                                    Padding="10,5,10,5"
                                    Width="200"
                                    ItemsSource="{Binding CpuCoreLimitOptions}"
                                    SelectedItem="{Binding SelectedCpuCoreLimit, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </controls:OptionControl>

                        <controls:OptionControl
                            Header="FPS Cap"
                            Description="Set Roblox framerate cap in GlobalBasicSettings. Use 0 for Roblox default.">
                            <ui:TextBox
                                Width="100"
                                Margin="5,0,0,0"
                                Padding="10,5,10,5"
                                Text="{Binding FramerateCap, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                        </controls:OptionControl>

                        <controls:OptionControl
                            Header="Graphics Quality"
                            Description="Set Roblox manual graphics level. Automatic lets Roblox choose.">
                            <ComboBox
                                Width="200"
                                Margin="5,0,0,0"
                                Padding="10,5,10,5"
                                ItemsSource="{Binding GraphicsQualityOptions}"
                                DisplayMemberPath="Name"
                                SelectedValuePath="Value"
                                SelectedValue="{Binding GraphicsQuality, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </controls:OptionControl>

                            <controls:OptionControl Header="Trim Roblox Memory" Description="Legacy one-shot trim. Smart RAM Governor takes priority when enabled.">
                                 <ui:ToggleSwitch IsChecked="{Binding MultiAccount, Mode=TwoWay}" />
                             </controls:OptionControl>

                             <controls:OptionControl Header="Optimize Roblox" Description="Optimizes Roblox based on your current CPU, GPU, and memory.">
                             <ui:ToggleSwitch IsChecked="{Binding OptimizeRoblox, Mode=TwoWay}" />
                         </controls:OptionControl>

                            <controls:OptionControl Header="Smart RAM Governor" Description="{Binding SmartMemoryGovernorDescription}">
                                <StackPanel Width="260" Margin="0,5,0,0">
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            Text="Safe RAM level"
                                            Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        <TextBlock
                                            Grid.Column="1"
                                            VerticalAlignment="Center"
                                            Text="{Binding SmartMemoryGovernorLevelText}"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                    </Grid>
                                    <Slider
                                        Minimum="0"
                                        Maximum="4"
                                        TickFrequency="1"
                                        IsSnapToTickEnabled="True"
                                        TickPlacement="BottomRight"
                                        Value="{Binding SmartMemoryGovernorLevel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <Grid Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Off" FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                        <TextBlock Grid.Column="1" Text="Balanced" FontSize="11" HorizontalAlignment="Center" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                        <TextBlock Grid.Column="2" Text="Bot Farm" FontSize="11" HorizontalAlignment="Right" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                    </Grid>
                                </StackPanel>
                            </controls:OptionControl>

                             <controls:OptionControl
    Header="Roblox Memory Cleaner"
    Description="Legacy forced cleaner. It is skipped automatically while Smart RAM Governor is enabled.">

                                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                    <ComboBox
    ItemsSource="{Binding MemoryCleanerIntervals}"
    DisplayMemberPath="Name"
    SelectedItem="{Binding SelectedMemoryCleanerInterval, Mode=TwoWay}" />

                                </StackPanel>

                            </controls:OptionControl>

                        </StackPanel>
                </ui:CardExpander>
            </StackPanel>
        </TabItem>
        
        </TabControl>
    </StackPanel>
</ui:UiPage>

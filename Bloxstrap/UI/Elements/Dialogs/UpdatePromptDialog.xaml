<base:WpfUiWindow
    x:Class="Voidstrap.UI.Elements.Dialogs.UpdatePromptDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:base="clr-namespace:Voidstrap.UI.Elements.Base"
    xmlns:controls="clr-namespace:Voidstrap.UI.Elements.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="NullCore Update"
    Width="580"
    MinWidth="520"
    Height="520"
    MinHeight="420"
    ResizeMode="NoResize"
    ExtendsContentIntoTitleBar="True"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Offset="0.0" Color="{DynamicResource WindowBackgroundColorPrimary}" />
                <GradientStop Offset="0.45" Color="{DynamicResource WindowBackgroundColorSecondary}" />
                <GradientStop Offset="1.0" Color="{DynamicResource WindowBackgroundColorPrimary}" />
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar
            x:Name="RootTitleBar"
            Padding="8"
            Title="NullCore Update"
            ShowMinimize="False"
            ShowMaximize="False"
            CanMaximize="False" />

        <Grid Grid.Row="1" Margin="20,14,20,18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock
                x:Name="UpdateTitleText"
                FontSize="22"
                FontWeight="SemiBold"
                TextWrapping="Wrap"
                Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

            <TextBlock
                x:Name="VersionText"
                Grid.Row="1"
                Margin="0,6,0,0"
                FontSize="13"
                TextWrapping="Wrap"
                Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

            <TextBlock
                Grid.Row="2"
                Margin="0,18,0,8"
                FontSize="14"
                FontWeight="SemiBold"
                Text="What's new"
                Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

            <Border
                Grid.Row="3"
                Padding="12"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="6">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <controls:MarkdownTextBlock
                        x:Name="ReleaseNotesText"
                        TextWrapping="Wrap"
                        Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                </ScrollViewer>
            </Border>
        </Grid>

        <Border
            Grid.Row="2"
            Padding="16"
            Background="{DynamicResource PrimaryBackgroundColor}">
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button
                    x:Name="SkipButton"
                    MinWidth="100"
                    Content="Not now"
                    Click="SkipButton_Click" />
                <Button
                    x:Name="DownloadButton"
                    MinWidth="140"
                    Margin="12,0,0,0"
                    Content="Download update"
                    Click="DownloadButton_Click" />
            </StackPanel>
        </Border>
    </Grid>
</base:WpfUiWindow>

<base:WpfUiWindow
    x:Class="Voidstrap.UI.Elements.About.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:base="clr-namespace:Voidstrap.UI.Elements.Base"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pages="clr-namespace:Voidstrap.UI.Elements.About.Pages"
    xmlns:resources="clr-namespace:Voidstrap.Resources"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="{x:Static resources:Strings.About_Title}"
    Width="860"
    Height="560"
    MinWidth="860"
    MinHeight="540"
    Background="#FF070A0E"
    BorderBrush="#243A4654"
    BorderThickness="1"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Disable"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <Grid>
        <Grid.Background>
            <SolidColorBrush Color="#FF070A0E" />
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar
            x:Name="RootTitleBar"
            Grid.Row="0"
            Padding="8"
            Title="{x:Static resources:Strings.About_Title}"
            Icon="pack://application:,,,/Voidstrap.ico"
            ForceShutdown="False"
            MinimizeToTray="False"
            UseSnapLayout="True" />

        <Grid
            x:Name="RootGrid"
            Grid.Row="1"
            Margin="12,12,12,12">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ui:NavigationStore
                x:Name="RootNavigation"
                Grid.Row="1"
                Grid.Column="0"
                Margin="0,0,12,0"
                Width="205"
                Padding="8"
                Background="#E812171E"
                BorderBrush="#243A4654"
                BorderThickness="1"
                Frame="{Binding ElementName=RootFrame}"
                SelectedPageIndex="0">

                <ui:NavigationStore.Items>
                    <ui:NavigationItem
                        Margin="0,0,0,12"
                        Content="{x:Static resources:Strings.Menu_About_Title}"
                        Icon="QuestionCircle48"
                        IconFilled="True"
                        PageType="{x:Type pages:AboutPage}"
                        Tag="about" />

                    <ui:NavigationItem
                        Margin="0,0,0,12"
                        Content="{x:Static resources:Strings.About_Licenses_Title}"
                        Icon="Code24"
                        PageType="{x:Type pages:LicensesPage}"
                        Tag="licenses" />
                </ui:NavigationStore.Items>
            </ui:NavigationStore>

            <Frame
                x:Name="RootFrame"
                Grid.Row="0"
                Grid.RowSpan="2"
                Grid.Column="1"
                Background="#E80F141A"
                BorderBrush="#243A4654"
                Navigated="RootFrame_Navigated" />
        </Grid>
    </Grid>
</base:WpfUiWindow>

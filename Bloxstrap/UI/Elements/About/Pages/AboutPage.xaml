<ui:UiPage
    x:Class="Voidstrap.UI.Elements.About.Pages.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="AboutPage"
    d:DesignHeight="720"
    d:DesignWidth="800"
    Scrollable="True"
    mc:Ignorable="d">

    <StackPanel Margin="0,0,14,14">
        <Grid Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="72" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border
                Width="56"
                Height="56"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <Image
                    Width="38"
                    Height="38"
                    Source="pack://application:,,,/Voidstrap.ico" />
            </Border>

            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock
                    FontSize="28"
                    FontWeight="SemiBold"
                    Text="NullCore" />
                <TextBlock
                    Margin="0,4,0,0"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                    Text="Personal Roblox bootstrapper maintained by the NullCore team."
                    TextWrapping="Wrap" />
            </StackPanel>
        </Grid>

        <WrapPanel Margin="0,0,0,22">
            <ui:Anchor
                Margin="0,0,8,8"
                Appearance="Secondary"
                Content="GitHub"
                Icon="Code24"
                NavigateUri="https://github.com/T1nkq/NullCore" />
            <ui:Anchor
                Margin="0,0,8,8"
                Appearance="Secondary"
                Content="Issues"
                Icon="ChatHelp24"
                NavigateUri="https://github.com/T1nkq/NullCore/issues" />
            <ui:Anchor
                Margin="0,0,8,8"
                Appearance="Secondary"
                Content="Releases"
                Icon="ArrowDownload24"
                NavigateUri="https://github.com/T1nkq/NullCore/releases" />
        </WrapPanel>

        <TextBlock
            Margin="0,0,0,10"
            FontSize="18"
            FontWeight="SemiBold"
            Text="Core Team" />

        <Grid Margin="0,0,0,22">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ui:Card Padding="16">
                <StackPanel>
                    <TextBlock
                        FontSize="20"
                        FontWeight="SemiBold"
                        Text="t1nkq" />
                    <TextBlock
                        Margin="0,4,0,0"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="Owner &amp; Developer" />
                    <TextBlock
                        Margin="0,10,0,0"
                        Text="Project owner, NullCore maintainer, and release owner."
                        TextWrapping="Wrap" />
                </StackPanel>
            </ui:Card>

            <ui:Card Grid.Column="2" Padding="16">
                <StackPanel>
                    <TextBlock
                        FontSize="20"
                        FontWeight="SemiBold"
                        Text="DeniskaaaXD" />
                    <TextBlock
                        Margin="0,4,0,0"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="Developer" />
                    <TextBlock
                        Margin="0,10,0,0"
                        Text="NullCore developer."
                        TextWrapping="Wrap" />
                </StackPanel>
            </ui:Card>
        </Grid>

        <StackPanel Visibility="{Binding BuildInformationVisibility, Mode=OneTime}">
            <TextBlock
                Margin="0,0,0,10"
                FontSize="18"
                FontWeight="SemiBold"
                Text="Build Information" />

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="28" />
                    <RowDefinition Height="28" />
                    <RowDefinition Height="28" />
                    <RowDefinition Height="28" />
                </Grid.RowDefinitions>

                <TextBlock
                    FontWeight="SemiBold"
                    Text="Updated"
                    Visibility="{Binding BuildCommitVisibility, Mode=OneTime}" />
                <TextBlock
                    Grid.Column="1"
                    Text="{Binding BuildTimestamp, Mode=OneTime}"
                    Visibility="{Binding BuildCommitVisibility, Mode=OneTime}" />

                <TextBlock
                    Grid.Row="1"
                    FontWeight="SemiBold"
                    Text="Version" />
                <TextBlock
                    Grid.Row="1"
                    Grid.Column="1"
                    Text="{Binding Version, Mode=OneTime}" />

                <TextBlock
                    Grid.Row="2"
                    FontWeight="SemiBold"
                    Text="Commit Hash"
                    Visibility="{Binding BuildCommitVisibility, Mode=OneTime}" />
                <TextBlock
                    Grid.Row="2"
                    Grid.Column="1"
                    Text="{Binding BuildMetadata.CommitHash, Mode=OneTime}"
                    Visibility="{Binding BuildCommitVisibility, Mode=OneTime}" />

                <TextBlock
                    Grid.Row="3"
                    FontWeight="SemiBold"
                    Text="Commit Ref"
                    Visibility="{Binding BuildCommitVisibility, Mode=OneTime}" />
                <TextBlock
                    Grid.Row="3"
                    Grid.Column="1"
                    Text="{Binding BuildMetadata.CommitRef, Mode=OneTime}"
                    Visibility="{Binding BuildCommitVisibility, Mode=OneTime}" />
            </Grid>
        </StackPanel>
    </StackPanel>
</ui:UiPage>
